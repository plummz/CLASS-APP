# ── Cloudflare R2 Storage ─────────────────────────────────
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=class-app-storage

# ── Supabase ──────────────────────────────────────────────
# These are served to the frontend via /api/config
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=
# Server-only key used for trusted profile/admin writes.
SUPABASE_SERVICE_KEY=

# ── AI Services ───────────────────────────────────────────
GEMINI_API_KEY=
GROQ_API_KEY=

# ── YouTube Search ────────────────────────────────────────
YOUTUBE_API_KEY=

# ── Push Notifications ────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@class-app.local

# ── Auth & Security ───────────────────────────────────────
# ADMIN_PASSWORD MUST be a bcrypt hash. Plaintext passwords are rejected.
# Generate one with:
#   node -e "require('bcryptjs').hash('yourpassword', 12).then(console.log)"
# Then paste the resulting $2b$12$... hash as the value below.
ADMIN_USERNAME=
ADMIN_PASSWORD=
# JWT_SECRET must be set in production (server refuses to start without it).
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=generate-a-long-random-string-here

# ── CORS ──────────────────────────────────────────────────
# Set to your deployed domain in production, e.g. https://class-app-1.onrender.com
ALLOWED_ORIGIN=

# ── Server ────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
