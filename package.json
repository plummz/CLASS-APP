{
  "name": "class-app",
  "version": "1.5.64",
  "description": "School portfolio app with real-time chat, profiles, and file uploads.",
  "main": "server.js",
  "scripts": {
    "prestart": "node scripts/cache-bust.js",
    "start": "node server.js",
